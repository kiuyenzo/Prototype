# NF Service Container
# Business Logic Only - called by Veramo Sidecar

FROM node:20-alpine

# Install curl for health checks
RUN apk add --no-cache curl

WORKDIR /app

# Copy sidecar code (compiled JS)
COPY sidecar/nf-service.js ./sidecar/

# Default environment
ENV NF_PORT=3000
ENV VERAMO_PORT=3001

EXPOSE 3000

# Health check
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
  CMD curl -f http://localhost:3000/health || exit 1

CMD ["node", "sidecar/nf-service.js"]
