
shortcuts
alias delete='k3d cluster delete cluster-a cluster-b'
alias start='k3d cluster start cluster-a cluster-b'
alias stop='k3d cluster stop cluster-a cluster-b'

switch cluster
kubectl config get-contexts
kubectl config use-context k3d-cluster-b
kubectl config use-context k3d-cluster-a

basics
k3d cluster list
kubectl get pod  # -o wide für IP #serivces - list resources # -n acapy
	kubectl get pods -n proxy
	kubectl get pods -A -o wide --field-selector spec.nodeName=k3d-cluster-a-agent-0
kubectl get nodes
kubectl describe #** 
kubectl logs {pod-name}
kubectl exec {pod-name} 
kubectl get ns
kubectl get all --all-namespaces

kubectl -n proxy get svc envoy-a
kubectl get events 
kubectl get services
	kubectl get svc -n acapy
kubectl get deployments #-n acapy
kubectl exec -it {pod-name} -- bin/bash
kubectl config view
kubectl get all -A -o wide   

suche nach Dateien
find cluster-a -name "*.yaml"


# alle container zeigen
kubectl --context k3d-cluster-a get pods --all-namespaces -o json | \
jq -r '.items[] | 
  "Pod: \(.metadata.namespace)/\(.metadata.name)\n" +
  "  Init Containers: \(if .spec.initContainers then [.spec.initContainers[].name] | join(", ") else "none" end)\n" +
  "  Containers: \([.spec.containers[].name] | join(", "))\n"'

